[run]
source = swigi
omit =
    # GUI macOS (rumps/AppKit) — non testable headless
    swigi/gui.py
    # Chargement bibliothèque C native — non testable sans hardware
    swigi/hidapi_loader.py
    # Point d'entrée (signaux, locks, rumps) — testé via run_daemon
    swigi/main.py
    swigi/__main__.py

[report]
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    raise NotImplementedError
